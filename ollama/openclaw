#!/bin/bash
docker run --rm -it --network=container:ollama-server-1 \
           -e OLLAMA_HOST=host.docker.internal \
           -v ~/.ollama_openclaw:/home/ubuntu/.openclaw \
           -v ~/.ollama:/home/ubuntu/.ollama \
           -v ~/.nvm:/home/ubuntu/.nvm \
           jianshao/ollama openclaw $*